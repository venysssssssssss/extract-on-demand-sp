# ─── SAP GUI Credentials ───────────────────────────────
# Copie este arquivo para .env e preencha os valores.
# O .env NUNCA deve ser commitado no repositório.
# Compatibilidade: o loader também aceita SAP_USER e SAP_PASS.

SAP_USERNAME=
SAP_PASSWORD=
SAP_CLIENT=
SAP_LANGUAGE=PT
SAP_POST_LOGIN_SLEEP_SECONDS=0

# ─── Control Plane ─────────────────────────────────────
DATABASE_URL=postgresql+psycopg://sap_automation:sap_automation@localhost:5432/sap_automation
REDIS_URL=redis://localhost:6379/0
SAP_OUTPUT_ROOT=output
SAP_QUEUE_NAME=sap-default
SAP_SCHEDULER_POLL_SECONDS=15
SAP_RUNNER_POLL_SECONDS=5
SAP_RUNNER_HEARTBEAT_SECONDS=15
SAP_RUNNER_ID=
