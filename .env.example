# Copie para .env e preencha os valores reais.
# O .env NUNCA deve ser commitado no repositório.

# ─── Perfil da máquina ─────────────────────────────────
# ubuntu-control-plane: VM Ubuntu/Docker em 10.71.202.127.
# windows-sap-runner: Windows 10 com SAP GUI interativo.
MACHINE_PROFILE=ubuntu-control-plane
CONTROL_PLANE_HOST=10.71.202.127
SAP_API_PORT=18000
CONTROL_PLANE_BASE_URL=http://10.71.202.127:18000

# ─── Control plane Docker: Postgres/Redis internos ─────
POSTGRES_DB=sap_automation
POSTGRES_USER=sap_automation
POSTGRES_PASSWORD=sap_automation
DATABASE_URL=postgresql+psycopg://sap_automation:sap_automation@postgres:5432/sap_automation
REDIS_URL=redis://redis:6379/0
SAP_OUTPUT_ROOT=/app/output
SAP_QUEUE_NAME=sap-default
SAP_SCHEDULER_POLL_SECONDS=15
SAP_RUNNER_POLL_SECONDS=5
SAP_RUNNER_HEARTBEAT_SECONDS=15
DB_RUNNER_ID=ubuntu-db-runner

# ─── Banco ENEL/SQL Server usado pelo db-runner ────────
# Alternativa A: informe diretamente global.database_url no sap_iw69_batch_config.json.
# Alternativa B: preencha estas variáveis para o código montar a URL mssql+pyodbc.
ENEL_SQL_HOST=
ENEL_SQL_PORT=1433
ENEL_SQL_DATABASE=ENEL
ENEL_SQL_USER=
ENEL_SQL_PASSWORD=
ENEL_SQL_DRIVER=ODBC Driver 17 for SQL Server
ENEL_SQL_TABLE=TBL_REINCIDENCIA_SM

# ─── Windows SAP runner ────────────────────────────────
# No Windows, sobrescreva DATABASE_URL/REDIS_URL para apontar para a VM:
# DATABASE_URL=postgresql+psycopg://sap_automation:sap_automation@10.71.202.127:5432/sap_automation
# REDIS_URL=redis://10.71.202.127:6379/0
# SAP_OUTPUT_ROOT=output
# SAP_QUEUE_NAME=sap-default
# SAP_RUNNER_ID=windows-sap-runner-01

SAP_RUNNER_ID=
SAP_USERNAME=
SAP_PASSWORD=
SAP_CLIENT=
SAP_LANGUAGE=PT
SAP_POST_LOGIN_SLEEP_SECONDS=0

# ─── Workflow SM/SALA_MERCADO ──────────────────────────
SM_WORKFLOW_TYPE=sm_sala_mercado_daily
SM_DEMANDANTE=SALA_MERCADO
SM_DISTRIBUIDORA=São Paulo
SM_REFERENCE=current_month
SM_CONFIG_PATH=sap_iw69_batch_config.json
